# Development .env configuration for optimal performance
# Optimized for local development environment

APP_NAME="Lumin Park Housing"
APP_ENV=local
APP_KEY=base64:1MeVTECbm54Aog28oK2ZvHrOEa3LsYdVkA3F6fEZDxA=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8000

# PHP CLI workers for development
PHP_CLI_SERVER_WORKERS=4

# Database configuration (MySQL with Laragon)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lumin_park_housing
DB_USERNAME=root
DB_PASSWORD=

# Cache configuration (file cache - simple for development)
CACHE_STORE=file
CACHE_PREFIX=lumin_park_dev

# Session configuration (file driver - simple for development)
SESSION_DRIVER=file
SESSION_LIFETIME=240
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Queue configuration (sync for immediate execution in development)
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=database

# File storage
FILESYSTEM_DISK=public

# Logging configuration (verbose for development)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Mail configuration (use log driver for development - no SMTP needed)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@luminpark.test"
MAIL_FROM_NAME="${APP_NAME}"

# Development debugging tools
TELESCOPE_ENABLED=true
DEBUGBAR_ENABLED=true
IGNITION_ENABLED=true

# Broadcast driver 
BROADCAST_DRIVER=log

# Asset versioning (disable for faster development)
VITE_APP_NAME="${APP_NAME}"

# Redis configuration for caching, sessions, and queues
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# File storage optimization
FILESYSTEM_DISK=public
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Logging configuration
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Mail configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Performance optimization settings
VIEW_CACHE_PATH=/tmp
ROUTE_CACHE_PATH=/tmp
CONFIG_CACHE_PATH=/tmp
SERVICES_CACHE_PATH=/tmp

# Opcache settings (add to php.ini or here if using docker)
# opcache.enable=1
# opcache.memory_consumption=256
# opcache.interned_strings_buffer=16
# opcache.max_accelerated_files=20000
# opcache.validate_timestamps=0
# opcache.revalidate_freq=0

# Asset versioning for cache busting
ASSET_URL=null
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Additional performance settings
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false
IGNITION_ENABLED=false

# Broadcast driver (for real-time features)
BROADCAST_DRIVER=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https